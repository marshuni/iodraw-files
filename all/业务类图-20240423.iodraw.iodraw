0" parent="bf6bjZ_MJacpVK8pF5pA-10"><mxGeometry x="0.8514" y="4" relative="1" as="geometry"><mxPoint x="11" y="-7" as="offset"/></mxGeometry></mxCell><mxCell id="0WAV6X6-Q7YRf2IlbYBR-2" value="使用" style="endArrow=open;endSize=12;dashed=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="1" source="Ak_Rz9p1av3eIKPjTx_U-3" edge="1"><mxGeometry x="-0.1207" y="65" width="160" relative="1" as="geometry"><mxPoint x="630" y="-280" as="sourcePoint"/><mxPoint x="370" y="-580" as="targetPoint"/><Array as="points"/><mxPoint x="-65" y="-70" as="offset"/></mxGeometry></mxCell><mxCell id="0WAV6X6-Q7YRf2IlbYBR-6" value="1" style="endArrow=open;html=1;endSize=12;startArrow=diamondThin;startSize=14;startFill=0;edgeStyle=orthogonalEdgeStyle;align=left;verticalAlign=bottom;" parent="1" edge="1"><mxGeometry x="-0.6667" y="20" relative="1" as="geometry"><mxPoint x="550" y="1000" as="sourcePoint"/><mxPoint x="430" y="1000" as="targetPoint"/><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="0WAV6X6-Q7YRf2IlbYBR-7" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;html=1;exitX=1.006;exitY=0.585;exitDx=0;exitDy=0;exitPerimeter=0;" parent="1" source="5d2195bd80daf111-19" edge="1"><mxGeometry width="160" relative="1" as="geometry"><mxPoint x="320" y="294" as="sourcePoint"/><mxPoint x="616" y="294" as="targetPoint"/></mxGeometry></mxCell><mxCell id="0WAV6X6-Q7YRf2IlbYBR-9" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="5d2195bd80daf111-10" target="5d2195bd80daf111-15" edge="1"><mxGeometry width="160" relative="1" as="geometry"><mxPoint x="720" y="440" as="sourcePoint"/><mxPoint x="880" y="440" as="targetPoint"/></mxGeometry></mxCell><mxCell id="lYmetMhcDjQ8O6GHYOWo-1" value="&lt;p style=&quot;line-height: 110%&quot;&gt;&lt;/p&gt;&lt;h2 align=&quot;left&quot;&gt;ContestPlatform&lt;/h2&gt;&lt;blockquote&gt;&lt;h3&gt;属性&lt;br&gt;&lt;/h3&gt;&lt;/blockquote&gt;&lt;p align=&quot;left&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;contest用于存储竞赛类，其键为竞赛ID，值为竞赛对象Contest&lt;/li&gt;&lt;li&gt;contestLevels 用于存储各项竞赛的等级，其键为等级，值为竞赛ID&lt;/li&gt;&lt;li&gt;contestLevels 用于存储各项竞赛的分类(科目)，其键为科目，值为竞赛ID&lt;/li&gt;&lt;/ul&gt;&lt;blockquote&gt;&lt;h3&gt;方法&lt;/h3&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;createContest(contestInfo: dict)方法通过字典传入某项竞赛的相关信息，创建成功后返回对应的竞赛ID。该方法由管理员调用。&lt;/li&gt;&lt;li&gt;对Contest的相关删改查操作同理。&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Courier New&quot;&gt;getContestsInfo()方法返回一个竞赛消息摘要的列表，列表中元素为字典，包括竞赛ID、竞赛名称与简要描述&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Courier New&quot;&gt;getContestInfo()方法根据关键字检索具体的竞赛，并返回竞赛的相关信息。相当于直接调用对应Contest类的同名方法。&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingTop=-6;" vertex="1" parent="1"><mxGeometry x="830" y="-605" width="410" height="300" as="geometry"/></mxCell></root></mxGraphModel>